generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id String @id @default(uuid())
  nome String
  email String @unique
  status String @default("Ativo")
  createdAt DateTime @default(now())

  cursoId   String?
  curso     Curso?   @relation("UsuariosDoCurso", fields: [cursoId], references: [id])

  cursosCoordenados Curso[] @relation("CoordenadorDoCurso")
}

model Curso {
  id        String   @id @default(uuid())
  nome      String
  metaHoras Int
  qtdAlunos  Int
  status    String   @default("Ativo")
  createdAt DateTime @default(now())

  coordenadorId String?
  coordenador   Usuario? @relation("CoordenadorDoCurso", fields: [coordenadorId], references: [id])

  usuarios Usuario[] @relation("UsuariosDoCurso")
}