generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  status    String   @default("Ativo")
  createdAt DateTime @default(now())

  tipo      TipoUsuario

  cursoId   String?
  curso     Curso?   @relation("CursoUsuarios", fields: [cursoId], references: [id])
  aluno     Aluno?   @relation("UsuarioAluno")
  atividadesValidadas Atividade[] @relation("ValidadorAtividade")
}

model Curso {
  id        String   @id @default(uuid())
  nome      String   @unique
  categoria String
  tipoCurso String
  duracao   String
  cargaHoraria Int
  status    String   @default("Ativo")
  createdAt DateTime @default(now())
  usuarios       Usuario[] @relation("CursoUsuarios")
  alunos         Aluno[]
  limites        Limite[]
}

model Aluno {
  id              String   @id @default(uuid())
  cpf             String   @unique

  usuarioId       String   @unique
  usuario         Usuario  @relation("UsuarioAluno", fields: [usuarioId], references: [id])

  cursoId         String
  curso           Curso    @relation(fields: [cursoId], references: [id])

  turma           Turma
  periodo         Int
  cargaExigida    Int

  atividades      Atividade[]

  createdAt       DateTime @default(now())
}

model Atividade {
  id               String   @id @default(uuid())
  titulo           String
  categoria        Categoria
  horasSolicitadas Int
  comprovante      String

  alunoId          String
  aluno            Aluno @relation(fields: [alunoId], references: [id])

  status           Status   @default(PENDENTE)
  horasAprovadas   Int?
  motivo           String?
  validadaPorId    String?
  validadaPor      Usuario? @relation("ValidadorAtividade", fields: [validadaPorId], references: [id])
  validadaEm       DateTime?

  createdAt        DateTime @default(now())
}

model Regra {
  id                         String   @id @default(uuid())
  verificaCoordenador        Boolean  @default(false)
  exigeCertificado           Boolean  @default(false)
  descricao                  String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Limite {
  id                 String   @id @default(uuid())
  cursoId            String
  curso              Curso    @relation(fields: [cursoId], references: [id])
  periodo            Int
  maxHorasPorPeriodo Int
  ensino             Int
  pesquisa           Int
  extensao           Int
  createdAt          DateTime @default(now())

  @@unique([cursoId, periodo])
}

enum TipoUsuario {
  SUPER_ADMIN
  COORDENADOR
  GESTOR
  ALUNO
}

enum Status {
  PENDENTE
  APROVADA
  REJEITADA
}

enum Categoria {
  ENSINO
  PESQUISA
  EXTENSAO
}

enum Turma {
  TADS047
  TADS048
  TADS049
}