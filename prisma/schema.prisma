generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Curso {
  id        String   @id @default(uuid())
  nome      String
  coordenador_responsavel String
  metaHoras Int
  qtdAlunos  Int
  status    String   @default("Ativo")
  createdAt DateTime @default(now())
}