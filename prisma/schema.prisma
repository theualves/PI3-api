generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id String @id @default(uuid())
  nome String
  email String @unique
  senha     String
  status String @default("Ativo")
  createdAt DateTime @default(now())
  tipo      String   // super-admin, coordenador, aluno
  cursoId   String?
  curso     Curso?   @relation("UsuariosDoCurso", fields: [cursoId], references: [id])

  cursosCoordenados Curso[] @relation("CoordenadorDoCurso")
}

model Curso {
  id        String   @id @default(uuid())
  nome      String
  metaHoras Int
  qtdAlunos  Int
  status    String   @default("Ativo")
  createdAt DateTime @default(now())

  usuarios       Usuario[] @relation("UsuariosDoCurso")
  coordenadores  Usuario[] @relation("CoordenadorDoCurso")

}

model Regra {
  id                         String   @id @default(uuid())
  exigeAprovacaoCoordenador  Boolean  @default(false)
  exigeCertificado           Boolean  @default(false)
  createdAt                  DateTime @default(now())
}

model Limite {
  id                 String   @id @default(uuid())
  maxHorasPorPeriodo Int
  ensino             Int
  pesquisa           Int
  extensao           Int
  createdAt          DateTime @default(now())
}